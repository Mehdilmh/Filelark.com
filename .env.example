# Anthropic API key — required only for the Image-to-Prompt tool.
# All other converters run 100% in the browser and need no keys.
ANTHROPIC_API_KEY=sk-ant-...

# Canonical site URL used in metadata, sitemap.xml and robots.txt
NEXT_PUBLIC_SITE_URL=https://filelark.com

# Set to "true" to render ad slots (leave off during development)
NEXT_PUBLIC_ADS_ENABLED=false

# --- Google integrations (all optional) ---
# Google Analytics 4 measurement ID (Admin → Data streams → Web)
NEXT_PUBLIC_GA_ID=
# Google Tag Manager container ID (only if you use GTM instead of / alongside GA)
NEXT_PUBLIC_GTM_ID=
# Search Console "HTML tag" verification content value (only needed if you
# don't verify via the domain/DNS method)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
