# --- AI provider keys (for the Image-to-Prompt tool only) ---
# All other converters run 100% in the browser and need no keys.
# Set at least ONE of these. If several are set, they act as automatic
# fallbacks in this order: Anthropic → OpenAI → Gemini. When one provider
# errors or is down, the next configured one is tried — the tool never breaks
# because a single API is unavailable.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides (sensible defaults are built in)
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
# OPENAI_VISION_MODEL=gpt-4o-mini
# GEMINI_VISION_MODEL=gemini-2.0-flash

# Canonical site URL used in metadata, sitemap.xml and robots.txt
NEXT_PUBLIC_SITE_URL=https://filelark.com

# --- AdSense ---
# Set to "true" to render ad slots (leave off during development)
NEXT_PUBLIC_ADS_ENABLED=false
# Your AdSense publisher ID (Account → Settings → Account information).
# Setting it loads the AdSense script and activates /ads.txt automatically.
NEXT_PUBLIC_ADSENSE_PUBLISHER=
# Optional: ad-unit slot IDs (create 3 display units in AdSense → Ads → By ad unit)
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_TOOL=
NEXT_PUBLIC_ADSENSE_SLOT_MID_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# --- Google integrations (all optional) ---
# Google Analytics 4 measurement ID (Admin → Data streams → Web)
NEXT_PUBLIC_GA_ID=
# Google Tag Manager container ID (only if you use GTM instead of / alongside GA)
NEXT_PUBLIC_GTM_ID=
# Search Console "HTML tag" verification content value (only needed if you
# don't verify via the domain/DNS method)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
